# MongoDB connection string (replace with your Atlas URI)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT secret — use a strong random string (min 32 chars)
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_replace_me

# Server port
PORT=5000

# Node environment
NODE_ENV=development

# Frontend origin(s) for CORS — comma-separated for multiple
CLIENT_URL=http://localhost:5173

# OpenAI API key (optional, for AI interview question generation)
# OPENAI_API_KEY=sk-...
